#port 
PORT=4400

#node environment
NODE_ENV=development

# Set to "true" to expose Swagger UI at /api/docs (auto-enabled when NODE_ENV != production).
# Keep disabled in production to save 60-120MB of heap on small containers.
ENABLE_SWAGGER=

# Postgres URL (use 127.0.0.1 locally to skip DNS resolver overhead)
DATABASE_URL=postgresql://kutz:kutz@127.0.0.1:5432/kutz

# When set to true/false, overrides auto-sync (default: sync when NODE_ENV is not production)
DATABASE_SYNCHRONIZE=

# In-memory API cache TTL (ms) for public lists and per-user order/booking lists
CACHE_TTL_MS=60000

# Set true to log critical actions even when NODE_ENV=production
AUDIT_LOG=

# Comma-separated Clerk user ids allowed to PATCH site settings (admin UI)
ADMIN_CLERK_USER_IDS=

# Clerk secret key (Dashboard → API Keys)
CLERK_SECRET_KEY=

#cors origins
CORS_ORIGINS=http://localhost:3000

# --- SMS (Twilio) ---
# When TWILIO_ACCOUNT_SID and TWILIO_AUTH_TOKEN are set, real SMS is used; otherwise logs use ConsoleSmsService.
# TWILIO_FROM_NUMBER: sender for admin alerts and customer texts. TWILIO_TO_NUMBER: staff number for booking-created SMS.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# --- Email: staff booking alerts (Resend) ---
# RESEND_API_KEY + EMAIL_FROM + NOTIFY_EMAIL_TO required or sendBookingCreated is skipped.
RESEND_API_KEY=
EMAIL_FROM=
NOTIFY_EMAIL_TO=

# --- Email: customer transactional (SendGrid) ---
# SENDGRID_API_KEY + EMAIL_FROM required for payment confirmation, reminders, thank-you; otherwise ConsoleCustomerEmailService.
SENDGRID_API_KEY=

# Stripe (copy Secret key from Dashboard → Developers → API keys; use .env locally, never commit real keys)
STRIPE_SECRET_KEY=

#stripe webhook secret
STRIPE_WEBHOOK_SECRET=
